// Kapis AI Platform - Prisma schema
//
// Sprint 11 wires Prisma to the existing PostgreSQL database only - it does not
// define business models yet. Schema changes still ship as versioned SQL files in
// database/migrations/ (applied manually), not via `prisma migrate`. Each Sprint 12+
// business module adds its own model(s) here (by hand, or via `npm run prisma:pull`
// against the already-applied migration) at the same time it wires up its API, so the
// Prisma schema never gets ahead of what the backend actually exposes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Mirrors database/migrations/002_create_doctors.sql (clinic.doctors). Schema
// resolution comes from DATABASE_URL's `?schema=clinic` query param, so no
// `@@schema(...)` attribute / multiSchema preview feature is needed.
model Doctor {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName            String   @map("first_name") @db.VarChar(100)
  lastName             String   @map("last_name") @db.VarChar(100)
  gender               String   @db.VarChar(10)
  specialization       String   @db.VarChar(150)
  qualification        String   @db.VarChar(150)
  experienceYears      Int      @default(0) @map("experience_years") @db.SmallInt
  registrationNumber   String   @unique @map("registration_number") @db.VarChar(50)
  phone                String   @db.VarChar(20)
  email                String   @unique @db.VarChar(255)
  consultationFee      Decimal  @map("consultation_fee") @db.Decimal(10, 2)
  consultationDuration Int      @default(15) @map("consultation_duration") @db.SmallInt
  status               String   @default("active") @db.VarChar(10)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("doctors")
}

// Mirrors database/migrations/003_create_doctor_schedules.sql (clinic.doctor_schedules).
// One row per (doctor, day-of-week); no surrogate id, same composite primary key
// the SQL table uses.
model DoctorSchedule {
  doctorId       String   @map("doctor_id") @db.Uuid
  dayOfWeek      String   @map("day_of_week") @db.VarChar(10)
  isWorking      Boolean  @default(true) @map("is_working")
  morningStart   DateTime @default(dbgenerated("'09:00'::time")) @map("morning_start") @db.Time(6)
  morningEnd     DateTime @default(dbgenerated("'13:00'::time")) @map("morning_end") @db.Time(6)
  afternoonStart DateTime @default(dbgenerated("'14:00'::time")) @map("afternoon_start") @db.Time(6)
  afternoonEnd   DateTime @default(dbgenerated("'18:00'::time")) @map("afternoon_end") @db.Time(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@id([doctorId, dayOfWeek])
  @@map("doctor_schedules")
}

// Mirrors database/migrations/004_create_doctor_leaves.sql (clinic.doctor_leaves).
model DoctorLeave {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  doctorId  String   @map("doctor_id") @db.Uuid
  leaveType String   @map("leave_type") @db.VarChar(20)
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  reason    String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("doctor_leaves")
}

// Mirrors database/migrations/005_create_clinic_holidays.sql (clinic.clinic_holidays).
model ClinicHoliday {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(150)
  holidayDate     DateTime @map("holiday_date") @db.Date
  recurringYearly Boolean  @default(false) @map("recurring_yearly")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("clinic_holidays")
}

// Mirrors database/migrations/006_create_patients.sql (clinic.patients).
model Patient {
  id                            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName                     String   @map("first_name") @db.VarChar(100)
  lastName                      String   @map("last_name") @db.VarChar(100)
  gender                        String   @db.VarChar(10)
  dateOfBirth                   DateTime @map("date_of_birth") @db.Date
  mobileNumber                  String   @map("mobile_number") @db.VarChar(20)
  whatsappNumber                String   @map("whatsapp_number") @db.VarChar(20)
  email                         String   @db.VarChar(255)
  bloodGroup                    String   @default("unknown") @map("blood_group") @db.VarChar(10)
  address                       String   @db.Text
  emergencyContactName          String   @map("emergency_contact_name") @db.VarChar(150)
  emergencyContactRelationship  String   @map("emergency_contact_relationship") @db.VarChar(100)
  emergencyContactPhone         String   @map("emergency_contact_phone") @db.VarChar(20)
  allergies                     String   @default("") @db.Text
  medicalNotes                  String   @default("") @map("medical_notes") @db.Text
  status                        String   @default("active") @db.VarChar(10)
  createdAt                     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("patients")
}

// Mirrors database/migrations/007_create_appointments.sql (clinic.appointments).
// The generated `start_at`/`end_at` timestamptz columns back the DB-level
// overlap exclusion constraint only - the API never reads or writes them, so
// they're intentionally left out of this model.
model Appointment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId       String   @map("patient_id") @db.Uuid
  doctorId        String   @map("doctor_id") @db.Uuid
  appointmentDate DateTime @map("appointment_date") @db.Date
  startTime       DateTime @map("start_time") @db.Time(6)
  endTime         DateTime @map("end_time") @db.Time(6)
  durationMinutes Int      @map("duration_minutes") @db.SmallInt
  appointmentType String   @map("appointment_type") @db.VarChar(20)
  status          String   @default("scheduled") @db.VarChar(10)
  notes           String   @default("") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("appointments")
}

// Mirrors database/migrations/033_create_workflow_executions.sql (clinic.workflow_executions).
// Append-only execution log for the n8n bridge (Sprint 15) - one row per
// POST /n8n/workflows/:id/trigger call, whether the webhook call to n8n
// succeeded or failed. No `updated_at`/trigger, same reasoning `Message`
// (023_create_messages.sql) uses: a row is never edited after it's written.
model WorkflowExecution {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId      String    @map("workflow_id") @db.VarChar(100)
  workflowName    String    @map("workflow_name") @db.VarChar(200)
  status          String    @db.VarChar(20)
  startedAt       DateTime  @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime? @map("finished_at") @db.Timestamptz(6)
  durationMs      Int?      @map("duration_ms")
  requestPayload  Json?     @map("request_payload") @db.JsonB
  responsePayload Json?     @map("response_payload") @db.JsonB
  errorMessage    String?   @map("error_message") @db.Text

  @@map("workflow_executions")
}
