  modelName    String   @map("model_name") @db.VarChar(100)
  displayName  String   @map("display_name") @db.VarChar(150)
  modelType    String   @default("chat") @map("model_type") @db.VarChar(20)
  isActive     Boolean  @default(true) @map("is_active")
  isDefault    Boolean  @default(false) @map("is_default")
  config       Json     @default("{}") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("ai_models")
}

// Mirrors database/migrations/037_create_ai_provider_logs.sql (clinic.ai_provider_logs).
// Sprint 18 (real Claude provider) - append-only, provider-billing-metrics-only
// log written by AiHistoryService.record() right after its AiExecutionHistory
// row, using that row's id as executionId. No updatedAt, same reasoning
// AiExecutionHistory itself uses. `cost` is a placeholder - always null until a
// future sprint adds real per-model pricing.
model AiProviderLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executionId     String   @map("execution_id") @db.Uuid
  provider        String   @db.VarChar(50)
  model           String   @db.VarChar(100)
  requestTokens   Int      @default(0) @map("request_tokens")
  responseTokens  Int      @default(0) @map("response_tokens")
  cost            Decimal? @db.Decimal(10, 6)
  latencyMs       Int      @default(0) @map("latency_ms")
  status          String   @default("success") @db.VarChar(20)
  errorMessage    String?  @map("error_message") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("ai_provider_logs")
}

// Mirrors database/migrations/015_create_doctor_profiles.sql (clinic.doctor_profiles).
// Sprint 19 (RAG Engine) - the "Doctor Profiles" knowledge source
// KnowledgeRetrievalService searches. Never had a Prisma model until now (see
// that migration's own header comment on why it's a separate table from
// Doctor); added here, additively, only because RagIndexerService/
// KnowledgeRepository need typed read access to count/join it, the same
// "read access only, no CRUD module" reasoning InsuranceProvider/
// AiPromptSetting above already use.
model DoctorProfile {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  doctorId         String   @unique @map("doctor_id") @db.Uuid
  biography        String   @default("") @db.Text
  languages        String[] @default([])
  awards           String[] @default([])
  certifications   String[] @default([])
  publications     String[] @default([])
  interests        String[] @default([])
  videoUrl         String   @default("") @map("video_url") @db.Text
  displayPriority  Int      @default(0) @map("display_priority") @db.SmallInt
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("doctor_profiles")
}

// Mirrors database/migrations/033_create_workflow_executions.sql (clinic.workflow_executions).
// Append-only execution log for the n8n bridge (Sprint 15) - one row per
// POST /n8n/workflows/:id/trigger call, whether the webhook call to n8n
// succeeded or failed. No `updated_at`/trigger, same reasoning `Message`
// (023_create_messages.sql) uses: a row is never edited after it's written.
model WorkflowExecution {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId      String    @map("workflow_id") @db.VarChar(100)
  workflowName    String    @map("workflow_name") @db.VarChar(200)
  status          String    @db.VarChar(20)
  startedAt       DateTime  @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime? @map("finished_at") @db.Timestamptz(6)
  durationMs      Int?      @map("duration_ms")
  requestPayload  Json?     @map("request_payload") @db.JsonB
  responsePayload Json?     @map("response_payload") @db.JsonB
  errorMessage    String?   @map("error_message") @db.Text

  @@map("workflow_executions")
}

// Mirrors database/migrations/039_create_whatsapp_messages.sql
// (clinic.whatsapp_messages). Sprint 20 (WhatsApp Cloud API) - see
// WhatsappModule. conversationId/messageId are nullable for the same reason
// the migration's header comment gives: a webhook can arrive for a number no
// patient record matches yet.
model WhatsappMessage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String?  @map("conversation_id") @db.Uuid
  messageId      String?  @map("message_id") @db.Uuid
  waMessageId    String   @default("") @map("wa_message_id") @db.VarChar(100)
  direction      String   @db.VarChar(10)
  messageType    String   @map("message_type") @db.VarChar(20)
  fromNumber     String   @default("") @map("from_number") @db.VarChar(20)
  toNumber       String   @default("") @map("to_number") @db.VarChar(20)
  body           String   @default("") @db.Text
  payload        Json     @default("{}") @db.JsonB
  status         String   @default("sent") @db.VarChar(15)
  errorMessage   String?  @map("error_message") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("whatsapp_messages")
}

// Mirrors database/migrations/040_create_whatsapp_events.sql
// (clinic.whatsapp_events). Append-only - no updatedAt, same reasoning
// WorkflowExecution/Message use.
model WhatsappEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType   String   @map("event_type") @db.VarChar(20)
  waMessageId String   @default("") @map("wa_message_id") @db.VarChar(100)
  status      String   @default("") @db.VarChar(15)
  payload     Json     @default("{}") @db.JsonB
  receivedAt  DateTime @default(now()) @map("received_at") @db.Timestamptz(6)

  @@map("whatsapp_events")
}

// Mirrors database/migrations/041_create_whatsapp_media.sql
// (clinic.whatsapp_media). Metadata only - see that migration's header
// comment on why no binary is ever downloaded or stored here.
model WhatsappMedia {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  whatsappMessageId String   @map("whatsapp_message_id") @db.Uuid
  mediaId           String   @default("") @map("media_id") @db.VarChar(100)
  mediaType         String   @map("media_type") @db.VarChar(20)
  mimeType          String   @default("") @map("mime_type") @db.VarChar(100)
  sha256            String   @default("") @db.VarChar(100)
  fileSize          Int?     @map("file_size")
  link              String   @default("") @db.Text
  caption           String   @default("") @db.Text
  filename          String   @default("") @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("whatsapp_media")
}

// Mirrors database/migrations/042_create_workflow_runtime.sql
// (clinic.workflow_runtime_executions). Sprint 21 - one row per end-to-end
// automated pipeline run (incoming WhatsApp message -> AI -> n8n -> decision
// -> reply). Has updatedAt since a run is mutated in place as it
// progresses (RUNNING -> COMPLETED/FAILED), unlike the append-only
// event/history tables above.
model WorkflowRuntimeExecution {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId    String?   @map("conversation_id") @db.Uuid
  messageId         String?   @map("message_id") @db.Uuid
  whatsappMessageId String?   @map("whatsapp_message_id") @db.Uuid
  aiExecutionId     String?   @map("ai_execution_id") @db.Uuid
  n8nExecutionId    String?   @map("n8n_execution_id") @db.Uuid
  triggerSource     String    @default("whatsapp_webhook") @map("trigger_source") @db.VarChar(30)
  decision          String?   @db.VarChar(20)
  // Sprint 25 - audit-only copy of the AI's intent/confidence for this run,
  // never read back into the next prompt (clinic.conversations.last_intent is
  // the mutable source of truth the pipeline actually consumes).
  intent            String?   @db.VarChar(30)
  intentConfidence  Decimal?  @map("intent_confidence") @db.Decimal(4, 3)
  status            String    @default("RUNNING") @db.VarChar(15)
  retryCount        Int       @default(0) @map("retry_count")
  aiLatencyMs       Int?      @map("ai_latency_ms")
  workflowLatencyMs Int?      @map("workflow_latency_ms")
  durationMs        Int?      @map("duration_ms")
  errorMessage      String?   @map("error_message") @db.Text
  startedAt         DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("workflow_runtime_executions")
}

// Mirrors database/migrations/043_create_workflow_runtime_logs.sql
// (clinic.workflow_runtime_logs). Append-only step-level trace for a
// WorkflowRuntimeExecution - no updatedAt, same reasoning Message/
// WhatsappEvent use.
model WorkflowRuntimeLog {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowRuntimeId  String   @map("workflow_runtime_id") @db.Uuid
  step               String   @db.VarChar(30)
  status             String   @db.VarChar(15)
  message            String   @default("") @db.Text
  metadata           Json     @default("{}") @db.JsonB
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("workflow_runtime_logs")
}

// Mirrors database/migrations/044_create_google_calendar.sql
// (clinic.google_calendar_connections). Sprint 22 - single-clinic OAuth
// connection (this schema has no clinic_id on Appointment either, see that
// model's own comment), so in practice this table holds at most one row -
// GoogleCalendarRepository always reads/writes the most recent one, same
// "singleton settings row" shape a future multi-clinic version could widen
// with a clinic_id column later without a breaking migration. Mutable
// (access/refresh token, expiry, status are all updated in place as
// GoogleCalendarService connects/refreshes/disconnects), so it gets an
// updated_at + trigger like clinic.workflow_runtime_executions.
model GoogleCalendarConnection {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accessToken    String    @default("") @map("access_token") @db.Text
  refreshToken   String    @default("") @map("refresh_token") @db.Text
  tokenExpiry    DateTime? @map("token_expiry") @db.Timestamptz(6)
  calendarId     String    @default("primary") @map("calendar_id") @db.VarChar(255)
  connectedEmail String    @default("") @map("connected_email") @db.VarChar(255)
  status         String    @default("disconnected") @db.VarChar(15)
  lastSyncAt     DateTime? @map("last_sync_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("google_calendar_connections")
}

// Mirrors database/migrations/045_create_google_calendar_sync.sql
// (clinic.google_calendar_sync_events). Sprint 22 - append-only sync-history
// trace (one row per create/update/delete attempt against Google Calendar,
// same "append-only step log" shape clinic.workflow_runtime_logs uses) that
// also doubles as the appointment_id <-> google_event_id link
// GoogleCalendarSyncService needs to update/delete the right event later -
// looked up via "most recent successful row for this appointment_id" rather
// than a separate mapping table, since the history itself already carries
// that information.
model GoogleCalendarSyncEvent {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Nullable: a Google push notification (GoogleCalendarWebhookService)
  // arrives with a channel/resource id, not an appointment id, until it's
  // been reconciled - see operation's 'NOTIFY' value.
  appointmentId String?  @map("appointment_id") @db.Uuid
  googleEventId String?  @map("google_event_id") @db.VarChar(255)
  operation     String   @db.VarChar(10)
  status        String   @db.VarChar(10)
  errorMessage  String?  @map("error_message") @db.Text
  // Free-form context - a NOTIFY row's channel/resource ids, or a
  // CREATE/UPDATE row's Google event id echoed back, same "flexible payload"
  // reason clinic.whatsapp_events.payload/clinic.workflow_runtime_logs.metadata use it.
  metadata      Json     @default("{}") @db.JsonB
  syncedAt      DateTime @default(now()) @map("synced_at") @db.Timestamptz(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("google_calendar_sync_events")
}

// Mirrors database/migrations/046_create_report_exports.sql
// (clinic.report_exports). Sprint 23 (Analytics & Reporting) - one row per
// export ExportService generates (CSV/Excel/PDF), written for the Exports
// page's history table. No updatedAt - an export record is never edited
// after it's written, same "append-only step log" reasoning
// clinic.workflow_runtime_logs/clinic.google_calendar_sync_events use.
model ReportExport {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportType   String    @map("report_type") @db.VarChar(30)
  format       String    @db.VarChar(10)
  filters      Json      @default("{}") @db.JsonB
  status       String    @default("completed") @db.VarChar(15)
  fileName     String    @map("file_name") @db.VarChar(255)
  rowCount     Int       @default(0) @map("row_count")
  requestedBy  String    @default("") @map("requested_by") @db.VarChar(200)
  errorMessage String?   @map("error_message") @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("report_exports")
}
