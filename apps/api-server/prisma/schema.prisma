// Mirrors database/migrations/022_create_conversations.sql (clinic.conversations).
// Sprint 16 (Conversation Engine) - see ConversationsModule.
model Conversation {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId         String   @map("patient_id") @db.Uuid
  channel           String   @default("whatsapp") @db.VarChar(20)
  status            String   @default("open") @db.VarChar(15)
  assignedToUserId  String?  @map("assigned_to_user_id") @db.Uuid
  tags              String[] @default([])
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("conversations")
}

// Mirrors database/migrations/023_create_messages.sql (clinic.messages). No
// updatedAt - a message is append-only except for the `read` flag (see the
// migration's own header comment).
model Message {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  direction      String   @db.VarChar(10)
  sender         String   @db.VarChar(10)
  senderName     String   @map("sender_name") @db.VarChar(200)
  body           String   @db.Text
  read           Boolean  @default(false)
  sentAt         DateTime @default(now()) @map("sent_at") @db.Timestamptz(6)

  @@map("messages")
}

// Mirrors database/migrations/024_create_conversation_notes.sql (clinic.conversation_notes).
model ConversationNote {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  authorName     String   @map("author_name") @db.VarChar(200)
  body           String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("conversation_notes")
}

// Mirrors database/migrations/025_create_conversation_assignments.sql
// (clinic.conversation_assignments). Append-only history - no updatedAt, same
// reasoning as Message.
model ConversationAssignment {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId   String   @map("conversation_id") @db.Uuid
  assignedToUserId String   @map("assigned_to_user_id") @db.Uuid
  assignedToRole   String   @map("assigned_to_role") @db.VarChar(20)
  assignedByName   String   @map("assigned_by_name") @db.VarChar(200)
  assignedAt       DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  @@map("conversation_assignments")
}

// Mirrors database/migrations/017_create_insurance_providers.sql (clinic.insurance_providers).
// Sprint 17 - read-only for ConversationContextBuilderService (AI Orchestration
// Engine); no InsuranceProvidersModule/CRUD exists yet, same "read access only"
// reasoning ConversationContextService's Clinic/Faq/Policy/MessageTemplate reads used.
model InsuranceProvider {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @db.VarChar(200)
  contactPerson String   @default("") @map("contact_person") @db.VarChar(150)
  phone         String   @default("") @db.VarChar(20)
  email         String   @default("") @db.VarChar(255)
  website       String   @default("") @db.Text
  status        String   @default("active") @db.VarChar(10)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("insurance_providers")
}

// Mirrors database/migrations/019_create_ai_prompt_settings.sql
// (clinic.ai_prompt_settings). Singleton row (`id smallint CHECK (id = 1)`) -
// read-only for ConversationContextBuilderService, same reasoning as
// InsuranceProvider above.
model AiPromptSetting {
  id                    Int      @id @default(1) @db.SmallInt
  clinicPersonality     String   @default("") @map("clinic_personality") @db.Text
  tone                  String   @default("") @db.VarChar(100)
  greeting              String   @default("") @db.Text
  fallbackMessage       String   @default("") @map("fallback_message") @db.Text
  emergencyInstructions String   @default("") @map("emergency_instructions") @db.Text
  escalationRules       String   @default("") @map("escalation_rules") @db.Text
  systemPrompt          String   @default("") @map("system_prompt") @db.Text
  enabled               Boolean  @default(false)
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("ai_prompt_settings")
}

// Mirrors database/migrations/034_create_prompt_templates.sql (clinic.prompt_templates).
// Sprint 17 (AI Orchestration Engine) - see PromptTemplateService, full CRUD owner.
model PromptTemplate {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String   @db.VarChar(200)
  type               String   @db.VarChar(30)
  description        String   @default("") @db.Text
  systemPrompt       String   @map("system_prompt") @db.Text
  userPromptTemplate String   @map("user_prompt_template") @db.Text
  variables          String[] @default([])
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("prompt_templates")
}

// Mirrors database/migrations/035_create_ai_execution_history.sql
// (clinic.ai_execution_history). Append-only execution log for AIExecutionService -
// no updatedAt, same reasoning Message (023_create_messages.sql) uses.
model AiExecutionHistory {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId    String    @map("conversation_id") @db.Uuid
  promptTemplateId  String?   @map("prompt_template_id") @db.Uuid
  systemPrompt      String    @map("system_prompt") @db.Text
  userPrompt        String    @map("user_prompt") @db.Text
  response          String    @default("") @db.Text
  model             String    @db.VarChar(100)
  provider          String    @db.VarChar(50)
  promptTokens      Int       @default(0) @map("prompt_tokens")
  completionTokens  Int       @default(0) @map("completion_tokens")
  totalTokens       Int       @default(0) @map("total_tokens")
  latencyMs         Int       @default(0) @map("latency_ms")
  finishReason      String    @default("") @map("finish_reason") @db.VarChar(30)
  status            String    @default("success") @db.VarChar(20)
  errorMessage      String?   @map("error_message") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("ai_execution_history")
}

// Mirrors database/migrations/036_create_ai_models.sql (clinic.ai_models).
// Catalog of AI models the orchestration pipeline can be pointed at - Sprint 17
// seeds exactly one 'mock' row (database/seed/003_ai_orchestration_seed.sql);
// no row is ever called over the network yet (see AIExecutionService).
model AiModel {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider     String   @db.VarChar(50)
  modelName    String   @map("model_name") @db.VarChar(100)
  displayName  String   @map("display_name") @db.VarChar(150)
  modelType    String   @default("chat") @map("model_type") @db.VarChar(20)
  isActive     Boolean  @default(true) @map("is_active")
  isDefault    Boolean  @default(false) @map("is_default")
  config       Json     @default("{}") @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("ai_models")
}

// Mirrors database/migrations/037_create_ai_provider_logs.sql (clinic.ai_provider_logs).
// Sprint 18 (real Claude provider) - append-only, provider-billing-metrics-only
// log written by AiHistoryService.record() right after its AiExecutionHistory
// row, using that row's id as executionId. No updatedAt, same reasoning
// AiExecutionHistory itself uses. `cost` is a placeholder - always null until a
// future sprint adds real per-model pricing.
model AiProviderLog {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  executionId     String   @map("execution_id") @db.Uuid
  provider        String   @db.VarChar(50)
  model           String   @db.VarChar(100)
  requestTokens   Int      @default(0) @map("request_tokens")
  responseTokens  Int      @default(0) @map("response_tokens")
  cost            Decimal? @db.Decimal(10, 6)
  latencyMs       Int      @default(0) @map("latency_ms")
  status          String   @default("success") @db.VarChar(20)
  errorMessage    String?  @map("error_message") @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("ai_provider_logs")
}

// Mirrors database/migrations/015_create_doctor_profiles.sql (clinic.doctor_profiles).
// Sprint 19 (RAG Engine) - the "Doctor Profiles" knowledge source
// KnowledgeRetrievalService searches. Never had a Prisma model until now (see
// that migration's own header comment on why it's a separate table from
// Doctor); added here, additively, only because RagIndexerService/
// KnowledgeRepository need typed read access to count/join it, the same
// "read access only, no CRUD module" reasoning InsuranceProvider/
// AiPromptSetting above already use.
model DoctorProfile {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  doctorId         String   @unique @map("doctor_id") @db.Uuid
  biography        String   @default("") @db.Text
  languages        String[] @default([])
  awards           String[] @default([])
  certifications   String[] @default([])
  publications     String[] @default([])
  interests        String[] @default([])
  videoUrl         String   @default("") @map("video_url") @db.Text
  displayPriority  Int      @default(0) @map("display_priority") @db.SmallInt
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("doctor_profiles")
}

// Mirrors database/migrations/033_create_workflow_executions.sql (clinic.workflow_executions).
// Append-only execution log for the n8n bridge (Sprint 15) - one row per
// POST /n8n/workflows/:id/trigger call, whether the webhook call to n8n
// succeeded or failed. No `updated_at`/trigger, same reasoning `Message`
// (023_create_messages.sql) uses: a row is never edited after it's written.
model WorkflowExecution {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId      String    @map("workflow_id") @db.VarChar(100)
  workflowName    String    @map("workflow_name") @db.VarChar(200)
  status          String    @db.VarChar(20)
  startedAt       DateTime  @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime? @map("finished_at") @db.Timestamptz(6)
  durationMs      Int?      @map("duration_ms")
  requestPayload  Json?     @map("request_payload") @db.JsonB
  responsePayload Json?     @map("response_payload") @db.JsonB
  errorMessage    String?   @map("error_message") @db.Text

  @@map("workflow_executions")
}
