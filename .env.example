# ==============================================================================
# Kapis AI Platform - Local Environment Template
# Copy this file to ".env" (same folder) and fill in real values.
# ".env" is git-ignored - never commit real secrets.
# ==============================================================================

# ---- PostgreSQL ----
# Host port defaults to 5434 (not 5432) so this stack can run alongside other
# local Postgres containers without a port collision. Change if 5434 is also taken.
POSTGRES_DB=kapis_ai
POSTGRES_USER=kapis_admin
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5434

# ---- pgAdmin ----
PGADMIN_DEFAULT_EMAIL=admin@kapis.ai
PGADMIN_DEFAULT_PASSWORD=change_me
PGADMIN_PORT=5050

# ---- n8n ----
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_ENCRYPTION_KEY=change_me_32_char_random_string
N8N_HOST=localhost
N8N_PROTOCOL=http
GENERIC_TIMEZONE=Asia/Kolkata

# ---- api-server (NestJS) ----
API_PORT=3000
# Comma-separated list of origins allowed to call the API (Angular dev server by default).
CORS_ORIGIN=http://localhost:4200
# Host-machine value for `npm run start:dev` inside apps/api-server (uses the
# published POSTGRES_PORT above). The api container in docker-compose.yml
# overrides this to point at the `postgres` service on the Docker network instead.
DATABASE_URL=postgresql://kapis_admin:change_me@localhost:5434/kapis_ai?schema=clinic

# ---- Auth (JWT) ----
# Both secrets must be at least 16 characters (enforced at api-server boot by
# src/config/env.validation.ts) - change these before anything but local dev.
# Access token - short-lived, sent on every request.
JWT_SECRET=change_me_access_token_secret
JWT_EXPIRES_IN=15m
# Refresh token - long-lived, only sent to POST /auth/refresh. Must differ from
# JWT_SECRET so a leaked access token can't be replayed as a refresh token.
JWT_REFRESH_SECRET=change_me_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=7d

# ---- AI Orchestration Engine - Claude provider (Sprint 18) ----
# Real Anthropic Messages API key. Leave blank for local dev without a key -
# ClaudeHealthService reports configured: false and POST /api/ai/generate fails
# with a clear configuration error instead of an opaque 401 from Anthropic.
ANTHROPIC_API_KEY=
# Model id sent on every request - see apps/api-server/src/claude/ for the full
# request/response mapping. Defaults to claude-sonnet-5 if left blank.
ANTHROPIC_MODEL=claude-sonnet-5
# Anthropic API base URL (no trailing slash) - ClaudeHttpService appends
# /v1/messages and /v1/models. Only override for a proxy or non-default region.
ANTHROPIC_API_URL=https://api.anthropic.com
# Per-request generation cap and sampling temperature (0-1). 1024/0.7 are sane
# defaults for short receptionist-style replies - see PromptBuilderService for
# what's actually sent as the prompt.
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TEMPERATURE=0.7
# Timeout (ms) applied to every outbound call to Claude (generate + health ping).
# 30000 is the default if unset.
ANTHROPIC_HTTP_TIMEOUT_MS=

# ---- OpenAI - not wired; AiProvider is the seam a future OpenAI provider plugs into ----
OPENAI_API_KEY=

# ---- Meta WhatsApp Cloud API (Sprint 20) ----
# Phone number id from the Meta App Dashboard (WhatsApp > API Setup). Leave
# blank for local dev without real credentials - PhoneNumberService reports
# connected: false and POST /api/whatsapp/send fails with a clear
# configuration error instead of an opaque 401 from Meta. The webhook
# receiver (verification + event/message persistence) still works without it.
WHATSAPP_PHONE_NUMBER_ID=
# Permanent (System User) access token - temporary tokens expire in 24h.
WHATSAPP_ACCESS_TOKEN=
# Arbitrary string you choose and enter in the Meta App Dashboard's webhook
# subscription form - GET /api/whatsapp/webhook echoes back hub.challenge
# only when hub.verify_token matches this value.
WHATSAPP_VERIFY_TOKEN=
# Graph API base URL (no trailing slash). Only override for a pinned API
# version other than the default below.
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
# Timeout (ms) applied to every outbound call to the WhatsApp Cloud API
# (send, phone number lookup). 15000 is the default if unset.
WHATSAPP_HTTP_TIMEOUT_MS=

# ---- Google Calendar API - wired in a later sprint ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ---- n8n Integration Bridge (api-server -> n8n) - Sprint 14/15 ----
# Base URL api-server calls to reach n8n (webhook trigger, health ping, workflow
# import). Defaults to the n8n container's own vars (N8N_PROTOCOL/N8N_HOST/N8N_PORT
# above) if left blank - only set this to point at a different n8n instance. The
# `api` service in docker-compose.yml overrides this to `http://n8n:5678` (the
# Docker network address) instead of using this host-machine value, the same way
# it overrides DATABASE_URL.
N8N_BRIDGE_BASE_URL=
# n8n API key, required for POST /api/n8n/workflows/import/:id (not for trigger or
# health, which don't need auth). Generate one from the n8n UI: log in to
# http://localhost:5678, Settings > n8n API > Create an API key.
N8N_API_KEY=
# Absolute path api-server reads workflow export JSON from. Leave blank for local
# dev (`npm run start:dev`) - it resolves to services/n8n-workflows/ two directories
# up from apps/api-server. docker-compose.yml overrides this to the container's
# mounted path.
N8N_WORKFLOWS_DIR=
# Timeout (ms) applied to every outbound call to n8n. 8000 is the default if unset.
N8N_HTTP_TIMEOUT_MS=
