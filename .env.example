# ==============================================================================
# Kapis AI Platform - Local Environment Template
# Copy this file to ".env" (same folder) and fill in real values.
# ".env" is git-ignored - never commit real secrets.
# ==============================================================================

# ---- PostgreSQL ----
# Host port defaults to 5434 (not 5432) so this stack can run alongside other
# local Postgres containers without a port collision. Change if 5434 is also taken.
POSTGRES_DB=kapis_ai
POSTGRES_USER=kapis_admin
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5434

# ---- pgAdmin ----
PGADMIN_DEFAULT_EMAIL=admin@kapis.ai
PGADMIN_DEFAULT_PASSWORD=change_me
PGADMIN_PORT=5050

# ---- n8n ----
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_ENCRYPTION_KEY=change_me_32_char_random_string
N8N_HOST=localhost
N8N_PROTOCOL=http
GENERIC_TIMEZONE=Asia/Kolkata

# ---- Auth (JWT) - wired in a later sprint, placeholders for now ----
JWT_SECRET=change_me
JWT_EXPIRES_IN=1d

# ---- AI Provider - wired in a later sprint ----
# Architecture supports swapping AI_PROVIDER between "claude" and "openai".
AI_PROVIDER=claude
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ---- Meta WhatsApp Cloud API - wired in a later sprint ----
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ---- Google Calendar API - wired in a later sprint ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
